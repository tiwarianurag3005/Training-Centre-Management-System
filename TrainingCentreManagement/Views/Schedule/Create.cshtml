@model TrainingCentreManagement.Models.Schedule

<h2>Create Schedule</h2>

<form asp-action="Create">

    Batch Id
    <input asp-for="BatchId" />

    <br><br>

    <label>Date & Time</label>
    <input type="datetime-local" asp-for="Date" />

    <br><br>

    Topic
    <input asp-for="Topic" />

    <br><br>

    <button type="submit">Save</button>

</form>