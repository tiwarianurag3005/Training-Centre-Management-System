@model TrainingCentreManagement.Models.Trainer

@{
    ViewData["Title"] = "Delete Trainer";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>Delete Trainer</h2>

<h3>Are you sure you want to delete this trainer?</h3>

<hr />

<p>
    <b>Name:</b> @Model.TrainerName
</p>

<p>
    <b>Email:</b> @Model.Email
</p>

<p>
    <b>Phone:</b> @Model.Phone
</p>

<p>
    <b>Expertise:</b> @Model.Expertise
</p>

<form asp-action="Delete" method="post">

    <input type="hidden" asp-for="TrainerId" />

    <button type="submit">Delete</button>

</form>

<br />

<a href="/Trainer">Cancel</a>